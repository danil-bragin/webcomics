{
  "title": "Webcomics — Pipeline Overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["webcomics", "pipeline"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total runs (completed)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(pipeline_runs_total{status=\"completed\"})", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total cost (USD)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(pipeline_step_cost_usd_total)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed runs",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(pipeline_runs_total{status=~\"failed|cancelled\"})", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Commands/sec",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(pipeline_commands_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Command p95 latency (by command)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, command) (rate(pipeline_command_duration_seconds_bucket[5m])))",
          "legendFormat": "{{command}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Commands by status",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(pipeline_commands_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Steps by type / status",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (step_type, status) (rate(pipeline_steps_total[5m]))",
          "legendFormat": "{{step_type}}/{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Cost by provider",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (provider) (pipeline_step_cost_usd_total)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } }
    }
  ]
}
