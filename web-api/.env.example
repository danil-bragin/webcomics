# Copy to web-api/.env and fill in. Never commit the real .env (it is gitignored).

ENV=dev
HTTP_PORT=8080

# Postgres — host port is 5433 (dev.compose.yml maps 5433:5432)
WRITE_DATABASE_URL=postgres://app:app@localhost:5433/app?sslmode=disable
READ_DATABASE_URL=postgres://app:app@localhost:5433/app?sslmode=disable

# Redis — host port is 6380 (dev.compose.yml maps 6380:6379)
REDIS_ADDR=localhost:6380

# MinIO (matches dev.compose.yml defaults)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=webcomics
MINIO_USE_SSL=false
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Provider API keys — get your own; leave blank to disable that feature
OPENROUTER_API_KEY=
FAL_KEY=
ELEVENLABS_API_KEY=
PIXABAY_API_KEY=
YOUTUBE_API_KEY=

# YouTube Data API OAuth (see docs/youtube-api-setup.md)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/api/youtube-oauth/callback

# Local Firefox profiles dir used by the Selenium upload fallback
FIREFOX_PROFILES_DIR=./ops/firefox-profiles
